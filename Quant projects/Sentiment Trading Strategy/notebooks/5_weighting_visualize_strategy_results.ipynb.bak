   "source": [
    "def filter_data_by_date_with_warmup(merged3, start_date=None, end_date=None, warmup_days=26):\n",
    "    \"\"\"\n",
    "    Filter dataset by date range but include warm-up period for calculations\n",
    "    \"\"\"\n",
    "    df = merged3.copy()\n",
    "    \n",
    "    if start_date:\n",
    "        analysis_start = pd.to_datetime(start_date)\n",
    "        # Include warm-up period for calculations\n",
    "        data_start = analysis_start - pd.Timedelta(days=warmup_days)\n",
    "        df = df[df.index >= data_start]\n",
    "        \n",
    "        print(f\"Data starts from: {data_start.strftime('%Y-%m-%d')} (warm-up)\")\n",
    "        print(f\"Analysis starts from: {analysis_start.strftime('%Y-%m-%d')}\")\n",
    "    else:\n",
    "        analysis_start = df.index[0]\n",
    "    \n",
    "    if end_date:\n",
    "        end_date = pd.to_datetime(end_date)\n",
    "        df = df[df.index <= end_date]\n",
    "        print(f\"Analysis ends: {end_date.strftime('%Y-%m-%d')}\")\n",
    "    \n",
    "    # Mark the analysis period\n",
    "    if start_date:\n",
    "        df['analysis_period'] = df.index >= analysis_start\n",
    "    else:\n",
    "        df['analysis_period'] = True\n",
    "        \n",
    "    return df, analysis_start\n",
    "\n",
    "def calculate_performance_metrics_realistic_filtered(df, analysis_start_date):\n",
    "    \"\"\"Calculate performance metrics only for the analysis period - FIXED VERSION\"\"\"\n",
    "    \n",
    "    # First, calculate cumulative returns for the ENTIRE dataset\n",
    "    df['cumulative_strategy_return'] = (1 + df['strategy_return']).cumprod() - 1\n",
    "    df['cumulative_buy_hold_return'] = (1 + df['buy_hold_return']).cumprod() - 1\n",
    "    \n",
    "    # Now filter to analysis period for performance metrics calculation\n",
    "    analysis_df = df[df['analysis_period']].copy()\n",
    "    \n",
    "    if len(analysis_df) == 0:\n",
    "        print(\"No data in analysis period!\")\n",
    "        return None, df\n",
    "    \n",
    "    # Get the starting values for the analysis period\n",
    "    analysis_start_idx = analysis_df.index[0]\n",
    "    \n",
    "    # Find the previous day's cumulative return to normalize from\n",
    "    prev_idx = df.index.get_loc(analysis_start_idx) - 1\n",
    "    if prev_idx >= 0:\n",
    "        prev_strategy_cum = df.iloc[prev_idx]['cumulative_strategy_return']\n",
    "        prev_bh_cum = df.iloc[prev_idx]['cumulative_buy_hold_return']\n",
    "    else:\n",
    "        prev_strategy_cum = 0\n",
    "        prev_bh_cum = 0\n",
    "    \n",
    "    # Calculate period-specific returns by normalizing from the start of analysis period\n",
    "    analysis_df['period_strategy_return'] = (\n",
    "        (1 + analysis_df['cumulative_strategy_return']) / (1 + prev_strategy_cum) - 1\n",
    "    )\n",
    "    analysis_df['period_buy_hold_return'] = (\n",
    "        (1 + analysis_df['cumulative_buy_hold_return']) / (1 + prev_bh_cum) - 1\n",
    "    )\n",
    "    \n",
    "    # Strategy statistics (only for analysis period)\n",
    "    strategy_returns = analysis_df['strategy_return'][analysis_df['strategy_return'] != 0]\n",
    "    buy_hold_returns = analysis_df['buy_hold_return']\n",
    "    \n",
    "    # Remove any NaN or infinite values\n",
    "    strategy_returns = strategy_returns.replace([np.inf, -np.inf], np.nan).dropna()\n",
    "    buy_hold_returns = buy_hold_returns.replace([np.inf, -np.inf], np.nan).dropna()\n",
    "    \n",
    "    if len(strategy_returns) == 0:\n",
    "        print(\"Warning: No strategy trades executed in analysis period!\")\n",
    "        return None, df\n",
    "    \n",
    "    # Performance metrics using the period-specific returns\n",
    "    total_strategy_return = analysis_df['period_strategy_return'].iloc[-1]\n",
    "    total_buy_hold_return = analysis_df['period_buy_hold_return'].iloc[-1]\n",
    "    \n",
    "    strategy_vol = strategy_returns.std() * np.sqrt(252) if len(strategy_returns) > 1 else 0\n",
    "    buy_hold_vol = buy_hold_returns.std() * np.sqrt(252) if len(buy_hold_returns) > 1 else 0\n",
    "    \n",
    "    strategy_sharpe = (strategy_returns.mean() * 252) / strategy_vol if strategy_vol > 0 else 0\n",
    "    buy_hold_sharpe = (buy_hold_returns.mean() * 252) / buy_hold_vol if buy_hold_vol > 0 else 0\n",
    "    \n",
    "    # Trade statistics\n",
    "    num_trades = len(strategy_returns)\n",
    "    win_rate = (strategy_returns > 0).mean() if len(strategy_returns) > 0 else 0\n",
    "    avg_win = strategy_returns[strategy_returns > 0].mean() if (strategy_returns > 0).any() else 0\n",
    "    avg_loss = strategy_returns[strategy_returns < 0].mean() if (strategy_returns < 0).any() else 0\n",
    "    \n",
    "    # Signal analysis\n",
    "    avg_holding_period = analysis_df[analysis_df['days_in_position'] > 0]['days_in_position'].mean()\n",
    "    avg_target = analysis_df['dynamic_target'].mean()\n",
    "    \n",
    "    # Maximum drawdown - calculate on period-specific returns\n",
    "    period_strategy_cum = (1 + analysis_df['strategy_return']).cumprod()\n",
    "    strategy_dd = (period_strategy_cum / period_strategy_cum.expanding().max()) - 1\n",
    "    max_strategy_dd = strategy_dd.min()\n",
    "    \n",
    "    period_bh_cum = (1 + analysis_df['buy_hold_return']).cumprod()\n",
    "    bh_dd = (period_bh_cum / period_bh_cum.expanding().max()) - 1\n",
    "    max_bh_dd = bh_dd.min()\n",
    "    \n",
    "    results = {\n",
    "        'Total Strategy Return': f\"{total_strategy_return:.2%}\",\n",
    "        'Total Buy & Hold Return': f\"{total_buy_hold_return:.2%}\",\n",
    "        'Strategy Volatility': f\"{strategy_vol:.2%}\",\n",
    "        'Buy & Hold Volatility': f\"{buy_hold_vol:.2%}\",\n",
    "        'Strategy Sharpe Ratio': f\"{strategy_sharpe:.3f}\",\n",
    "        'Buy & Hold Sharpe Ratio': f\"{buy_hold_sharpe:.3f}\",\n",
    "        'Number of Trades': num_trades,\n",
    "        'Win Rate': f\"{win_rate:.2%}\",\n",
    "        'Average Win': f\"{avg_win:.3%}\",\n",
    "        'Average Loss': f\"{avg_loss:.3%}\",\n",
    "        'Average Holding Period': f\"{avg_holding_period:.1f} days\" if not pd.isna(avg_holding_period) else \"N/A\",\n",
    "        'Average Target': f\"{avg_target:.3%}\",\n",
    "        'Max Strategy Drawdown': f\"{max_strategy_dd:.2%}\",\n",
    "        'Max Buy & Hold Drawdown': f\"{max_bh_dd:.2%}\",\n",
    "        'Excess Return': f\"{(total_strategy_return - total_buy_hold_return):.2%}\",\n",
    "        'Trading Days Only': \"Weekdays (Mon-Fri)\"\n",
    "    }\n",
    "    \n",
    "    return results, df\n",
    "\n",
    "def run_realistic_strategy_with_warmup(merged3, start_date=None, end_date=None, warmup_days=26):\n",
    "    \"\"\"\n",
    "    Run strategy with proper warm-up period\n",
    "    \"\"\"\n",
    "    print(\"=\"*70)\n",
    "    print(\"MULTI-TIMEFRAME TRADING STRATEGY BACKTEST (WITH WARM-UP)\")\n",
    "    print(\"=\"*70)\n",
    "    \n",
    "    # Filter data with warm-up period\n",
    "    if start_date or end_date:\n",
    "        filtered_data, analysis_start = filter_data_by_date_with_warmup(\n",
    "            merged3, start_date, end_date, warmup_days\n",
    "        )\n",
    "    else:\n",
    "        filtered_data = merged3.copy()\n",
    "        filtered_data['analysis_period'] = True\n",
    "        analysis_start = filtered_data.index[0]\n",
    "    \n",
    "    if len(filtered_data) < 100:\n",
    "        print(\"Warning: Insufficient data for analysis!\")\n",
    "        return None, None\n",
    "    \n",
    "    # Calculate ma30_overall_median from the ENTIRE original dataset for consistency\n",
    "    ma30_overall_median = merged3['sentiment_ewma30'].median()\n",
    "    \n",
    "    # Run strategy on filtered dataset (including warm-up)\n",
    "    print(\"\\nRunning strategy with warm-up period...\")\n",
    "    results_df = multi_timeframe_strategy_realistic(filtered_data, ma30_overall_median)\n",
    "    \n",
    "    # Calculate performance only for analysis period\n",
    "    print(\"\\nCalculating performance metrics for analysis period...\")\n",
    "    performance, results_df = calculate_performance_metrics_realistic_filtered(\n",
    "        results_df, analysis_start\n",
    "    )\n",
    "    \n",
    "    if performance is None:\n",
    "        return None, None\n",
    "    \n",
    "    # Display results\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"STRATEGY PERFORMANCE SUMMARY\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    for metric, value in performance.items():\n",
    "        print(f\"{metric:<30}: {value}\")\n",
    "    \n",
    "    return results_df, performance\n",
    "\n",
    "def walk_forward_analysis(merged3, window_months=12, step_months=3):\n",
    "    \"\"\"\n",
    "    Perform walk-forward analysis with overlapping periods\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    start_date = merged3.index[0]\n",
    "    end_date = merged3.index[-1]\n",
    "    \n",
    "    current_start = start_date\n",
    "    \n",
    "    while current_start < end_date:\n",
    "        current_end = min(\n",
    "            current_start + pd.DateOffset(months=window_months),\n",
    "            end_date\n",
    "        )\n",
    "        \n",
    "        if current_end - current_start < pd.Timedelta(days=180):  # Skip if too short\n",
    "            break\n",
    "            \n",
    "        period_label = f\"{current_start.strftime('%Y-%m')} to {current_end.strftime('%Y-%m')}\"\n",
    "        print(f\"\\nAnalyzing period: {period_label}\")\n",
    "        \n",
    "        try:\n",
    "            period_results, period_performance = run_realistic_strategy_with_warmup(\n",
    "                merged3, \n",
    "                start_date=current_start.strftime('%Y-%m-%d'),\n",
    "                end_date=current_end.strftime('%Y-%m-%d'),\n",
    "                warmup_days=365\n",
    "            )\n",
    "            \n",
    "            if period_performance:\n",
    "                results.append({\n",
    "                    'period': period_label,\n",
    "                    'start': current_start,\n",
    "                    'end': current_end,\n",
    "                    'performance': period_performance,\n",
    "                    'data': period_results\n",
    "                })\n",
    "        except Exception as e:\n",
    "            print(f\"Error analyzing period {period_label}: {e}\")\n",
    "        \n",
    "        # Move to next period\n",
    "        current_start += pd.DateOffset(months=step_months)\n",
    "    \n",
    "    return results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e37f4a9f-d0ea-460c-8916-2f691663476c",

   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from datetime import datetime\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "def multi_timeframe_strategy(merged3):\n",
    "    \"\"\"\n",
    "    Implement multi-timeframe confirmation trading strategy\n",
    "    \n",
    "    Strategy Rules:\n",
    "    Long Entry:\n",
    "    - Short-term: sentiment_ma3 > sentiment_ma7 (recent improvement)\n",
    "    - Medium-term: sentiment_ma14 trending upward (past 3 days)\n",
    "    - Long-term: sentiment_ma30 > historical median\n",
    "    - Confirmation: num_stocks > median (broad-based sentiment)\n",
    "    \n",
    "    Short Entry:\n",
    "    - Short-term: sentiment_ma3 < sentiment_ma7 (recent deterioration)\n",
    "    - Medium-term: sentiment_ma14 declining trend (past 3 days)\n",
    "    - Long-term: sentiment_ma30 < historical median\n",
    "    - Confirmation: declining breadth in positive sentiment stocks\n",
    "    \n",
    "    Exit:\n",
    "    - Any timeframe signal reverses\n",
    "    - Divergence between price and sentiment for 2+ days\n",
    "    - Profit targets: 2% for longs, 1.5% for shorts\n",
    "    \"\"\"\n",
    "    \n",
    "    # Create a copy to avoid modifying original data\n",
    "    df = merged3.copy()\n",
    "    \n",
    "    # Ensure data is sorted by date (assuming index is date)\n",
    "    df = df.sort_index()\n",
    "    \n",
    "    # Calculate additional required indicators\n",
    "    df['ma14_trend'] = df['sentiment_ewma14'].diff(3)  # 3-day change in MA14\n",
    "    df['ma30_median'] = df['sentiment_ewma30'].rolling(window=252, min_periods=50).median()  # Historical median\n",
    "    df['num_stocks_median'] = df['num_stocks'].rolling(window=252, min_periods=50).median()\n",
    "    \n",
    "    # Price-sentiment divergence tracking\n",
    "    df['price_change_3d'] = df['% Change'].rolling(window=3).sum()\n",
    "    df['sentiment_change_3d'] = df['weighted_sentiment'].diff(3)\n",
    "    \n",
    "    # Calculate thresholds\n",
    "    ma30_overall_median = df['sentiment_ewma30'].median()\n",
    "    num_stocks_overall_median = df['num_stocks'].median()\n",
    "    \n",
    "\n",
    "    \n",
    "    # Initialize strategy columns\n",
    "    df['position'] = 0\n",
    "    df['entry_signal'] = 0\n",
    "    df['exit_signal'] = 0\n",
    "    df['days_in_position'] = 0\n",
    "    df['entry_price'] = np.nan\n",
    "    df['strategy_return'] = 0.0\n",
    "    df['cumulative_strategy_return'] = 0.0\n",
    "    df['buy_hold_return'] = 0.0\n",
    "    df['cumulative_buy_hold_return'] = 0.0\n",
    "    \n",
    "    # Signal strength tracking\n",
    "    df['short_term_signal'] = 0  # 1: bullish, -1: bearish, 0: neutral\n",
    "    df['medium_term_signal'] = 0\n",
    "    df['long_term_signal'] = 0\n",
    "    #df['confirmation_signal'] = 0\n",
    "    df['total_signal_strength'] = 0\n",
    "    \n",
    "    # Strategy state variables\n",
    "    current_position = 0\n",
    "    days_held = 0\n",
    "    entry_price = 0\n",
    "    entry_date = None\n",
    "    divergence_days = 0\n",
    "    \n",
    "    for i in range(len(df)):\n",
    "        current_row = df.iloc[i]\n",
    "        \n",
    "        # Skip if we don't have enough data for all signals\n",
    "        if (pd.isna(current_row['sentiment_ewma30']) or \n",
    "            pd.isna(current_row['ma14_trend']) or\n",
    "            i < 3):  # Need at least 3 days for trend calculation\n",
    "            continue\n",
    "            \n",
    "        # Get current values\n",
    "        current_ma3 = current_row['sentiment_ewma3']\n",
    "        current_ma7 = current_row['sentiment_ewma7']\n",
    "        current_ma14 = current_row['sentiment_ewma14']\n",
    "        current_ma30 = current_row['sentiment_ewma30']\n",
    "        current_ma14_trend = current_row['ma14_trend']\n",
    "        current_num_stocks = current_row['num_stocks']\n",
    "        current_price = current_row['^OEX']\n",
    "        current_return = current_row['% Change']\n",
    "        current_sentiment = current_row['weighted_sentiment']\n",
    "        \n",
    "        # Calculate individual timeframe signals\n",
    "        \n",
    "        # 1. Short-term signal (MA3 vs MA7)\n",
    "        if current_ma3 > current_ma7:\n",
    "            short_term_sig = 1  # Bullish\n",
    "        # elif current_ma3 < current_ma7:\n",
    "        #     short_term_sig = -1  # Bearish\n",
    "        else:\n",
    "            short_term_sig = 0  # Neutral\n",
    "        \n",
    "        # 2. Medium-term signal (MA14 trend)\n",
    "        if current_ma14_trend > 0.001:  # Threshold to avoid noise\n",
    "            medium_term_sig = 1  # Bullish trend\n",
    "        # elif current_ma14_trend < -0.001:\n",
    "        #     medium_term_sig = -1  # Bearish trend\n",
    "        else:\n",
    "            medium_term_sig = 0  # Neutral\n",
    "        \n",
    "        # 3. Long-term signal (MA30 vs historical median)\n",
    "        if current_ma30 > ma30_overall_median:\n",
    "            long_term_sig = 1  # Above long-term average\n",
    "        # elif current_ma30 < ma30_overall_median:\n",
    "        #     long_term_sig = -1  # Below long-term average\n",
    "        else:\n",
    "            long_term_sig = 0\n",
    "        \n",
    "        # # 4. Confirmation signal (breadth)\n",
    "        # if current_num_stocks > num_stocks_overall_median:\n",
    "        #     confirmation_sig = 1  # Broad participation\n",
    "        # elif current_num_stocks < num_stocks_overall_median:\n",
    "        #     confirmation_sig = -1  # Narrow participation\n",
    "        # else:\n",
    "        #     confirmation_sig = 0\n",
    "        \n",
    "        # Store individual signals\n",
    "        df.iloc[i, df.columns.get_loc('short_term_signal')] = short_term_sig\n",
    "        df.iloc[i, df.columns.get_loc('medium_term_signal')] = medium_term_sig\n",
    "        df.iloc[i, df.columns.get_loc('long_term_signal')] = long_term_sig\n",
    "        #df.iloc[i, df.columns.get_loc('confirmation_signal')] = confirmation_sig\n",
    "        \n",
    "        # Calculate total signal strength\n",
    "        total_signal = short_term_sig + medium_term_sig + long_term_sig #+ confirmation_sig\n",
    "        df.iloc[i, df.columns.get_loc('total_signal_strength')] = total_signal\n",
    "        \n",
    "        # Check for price-sentiment divergence\n",
    "        if i >= 3:\n",
    "            price_3d = current_row['price_change_3d']\n",
    "            sentiment_3d = current_row['sentiment_change_3d']\n",
    "            \n",
    "            # Divergence: price and sentiment moving in opposite directions\n",
    "            if ((price_3d > 0 and sentiment_3d < -0.01) or \n",
    "                (price_3d < 0 and sentiment_3d > 0.01)):\n",
    "                divergence_days += 1\n",
    "            else:\n",
    "                divergence_days = 0\n",
    "        \n",
    "        # Check exit conditions first (if we have a position)\n",
    "        if current_position != 0:\n",
    "            days_held += 1\n",
    "            df.iloc[i, df.columns.get_loc('days_in_position')] = days_held\n",
    "            \n",
    "            exit_position = False\n",
    "            exit_reason = \"\"\n",
    "            \n",
    "            # Exit condition 1: Any timeframe signal reverses\n",
    "            if current_position == 1:  # Long position\n",
    "                if (short_term_sig < 0 or medium_term_sig < 0 or \n",
    "                    long_term_sig < 0 #or confirmation_sig < 0\n",
    "                   ):\n",
    "                    exit_position = True\n",
    "                    exit_reason = \"Signal reversal\"\n",
    "                # Profit target for longs: 2%\n",
    "                elif current_return >= 0.0001:\n",
    "                    exit_position = True\n",
    "                    exit_reason = \"Profit target (2%)\"\n",
    "            \n",
    "            # elif current_position == -1:  # Short position\n",
    "            #     if (short_term_sig > 0 or medium_term_sig > 0 or \n",
    "            #         long_term_sig > 0 or confirmation_sig > 0):\n",
    "            #         exit_position = True\n",
    "            #         exit_reason = \"Signal reversal\"\n",
    "            #     # Profit target for shorts: 1.5%\n",
    "            #     elif current_return <= -0.015:\n",
    "            #         exit_position = True\n",
    "            #         exit_reason = \"Profit target (1.5%)\"\n",
    "            \n",
    "            # Exit condition 2: Price-sentiment divergence for 2+ days\n",
    "            if divergence_days >= 2:\n",
    "                exit_position = True\n",
    "                exit_reason = \"Price-sentiment divergence\"\n",
    "            \n",
    "            # Exit condition 3: Maximum holding period (15 days for this strategy)\n",
    "            if days_held >= 15:\n",
    "                exit_position = True\n",
    "                exit_reason = \"Max holding period\"\n",
    "            \n",
    "            if exit_position:\n",
    "                df.iloc[i, df.columns.get_loc('exit_signal')] = current_position\n",
    "                \n",
    "                # Calculate strategy return for this trade\n",
    "                if current_position == 1:  # Long position\n",
    "                    trade_return = current_return\n",
    "                else:  # Short position\n",
    "                    trade_return = -current_return\n",
    "                \n",
    "                df.iloc[i, df.columns.get_loc('strategy_return')] = trade_return\n",
    "                \n",
    "                # Reset position\n",
    "                current_position = 0\n",
    "                days_held = 0\n",
    "                entry_price = 0\n",
    "                entry_date = None\n",
    "                divergence_days = 0\n",
    "                \n",
    "\n",
    "        \n",
    "        # Check entry conditions (only if no current position)\n",
    "        if current_position == 0:\n",
    "            \n",
    "            # Long entry: All signals must be positive (total_signal = 4)\n",
    "            if total_signal >= 1:  # Allow for some flexibility (3 out of 4 signals)\n",
    "                \n",
    "                current_position = 1  # Long\n",
    "                entry_price = current_price\n",
    "                entry_date = df.index[i]\n",
    "                days_held = 0\n",
    "                divergence_days = 0\n",
    "                \n",
    "                df.iloc[i, df.columns.get_loc('entry_signal')] = 1\n",
    "                df.iloc[i, df.columns.get_loc('entry_price')] = entry_price\n",
    "                \n",
    "               # print(f\"Long entry at index {i}: Price={entry_price:.2f}, Signal strength={total_signal}\")\n",
    "               # print(f\"  ST:{short_term_sig}, MT:{medium_term_sig}, LT:{long_term_sig}, Conf:{confirmation_sig}\")\n",
    "            \n",
    "            # # Short entry: All signals must be negative (total_signal = -4)\n",
    "            # elif total_signal <= -3:  # Allow for some flexibility\n",
    "                \n",
    "            #     current_position = -1  # Short\n",
    "            #     entry_price = current_price\n",
    "            #     entry_date = df.index[i]\n",
    "            #     days_held = 0\n",
    "            #     divergence_days = 0\n",
    "                \n",
    "            #     df.iloc[i, df.columns.get_loc('entry_signal')] = -1\n",
    "            #     df.iloc[i, df.columns.get_loc('entry_price')] = entry_price\n",
    "                \n",
    "            #     print(f\"Short entry at index {i}: Price={entry_price:.2f}, Signal strength={total_signal}\")\n",
    "            #     print(f\"  ST:{short_term_sig}, MT:{medium_term_sig}, LT:{long_term_sig}, Conf:{confirmation_sig}\")\n",
    "        \n",
    "        # Update position\n",
    "        df.iloc[i, df.columns.get_loc('position')] = current_position\n",
    "        \n",
    "        # Calculate buy and hold return\n",
    "        df.iloc[i, df.columns.get_loc('buy_hold_return')] = current_return\n",
    "    \n",
    "    return df\n",
    "\n",
    "def calculate_performance_metrics_mtf(df):\n",
    "    \"\"\"Calculate comprehensive performance metrics for multi-timeframe strategy\"\"\"\n",
    "    \n",
    "    # Calculate cumulative returns\n",
    "    df['cumulative_strategy_return'] = (1 + df['strategy_return']).cumprod() - 1\n",
    "    df['cumulative_buy_hold_return'] = (1 + df['buy_hold_return']).cumprod() - 1\n",
    "    \n",
    "    # Strategy statistics\n",
    "    strategy_returns = df['strategy_return'][df['strategy_return'] != 0]\n",
    "    buy_hold_returns = df['buy_hold_return']\n",
    "    \n",
    "    # Remove any NaN or infinite values\n",
    "    strategy_returns = strategy_returns.replace([np.inf, -np.inf], np.nan).dropna()\n",
    "    buy_hold_returns = buy_hold_returns.replace([np.inf, -np.inf], np.nan).dropna()\n",
    "    \n",
    "    if len(strategy_returns) == 0:\n",
    "        print(\"Warning: No strategy trades executed!\")\n",
    "        return None, df\n",
    "    \n",
    "    # Performance metrics\n",
    "    total_strategy_return = df['cumulative_strategy_return'].iloc[-1]\n",
    "    total_buy_hold_return = df['cumulative_buy_hold_return'].iloc[-1]\n",
    "    \n",
    "    strategy_vol = strategy_returns.std() * np.sqrt(252)  # Annualized\n",
    "    buy_hold_vol = buy_hold_returns.std() * np.sqrt(252)\n",
    "    \n",
    "    strategy_sharpe = (strategy_returns.mean() * 252) / strategy_vol if strategy_vol > 0 else 0\n",
    "    buy_hold_sharpe = (buy_hold_returns.mean() * 252) / buy_hold_vol if buy_hold_vol > 0 else 0\n",
    "    \n",
    "    # Trade statistics\n",
    "    num_trades = len(strategy_returns)\n",
    "    win_rate = (strategy_returns > 0).mean() if len(strategy_returns) > 0 else 0\n",
    "    avg_win = strategy_returns[strategy_returns > 0].mean() if (strategy_returns > 0).any() else 0\n",
    "    avg_loss = strategy_returns[strategy_returns < 0].mean() if (strategy_returns < 0).any() else 0\n",
    "    \n",
    "    # Signal analysis\n",
    "    signal_strength_stats = df['total_signal_strength'].describe()\n",
    "    avg_holding_period = df[df['days_in_position'] > 0]['days_in_position'].mean()\n",
    "    \n",
    "    # Maximum drawdown\n",
    "    cumulative_strategy = (1 + df['strategy_return']).cumprod()\n",
    "    strategy_dd = (cumulative_strategy / cumulative_strategy.expanding().max()) - 1\n",
    "    max_strategy_dd = strategy_dd.min()\n",
    "    \n",
    "    cumulative_bh = (1 + df['buy_hold_return']).cumprod()\n",
    "    bh_dd = (cumulative_bh / cumulative_bh.expanding().max()) - 1\n",
    "    max_bh_dd = bh_dd.min()\n",
    "    \n",
    "    results = {\n",
    "        'Total Strategy Return': f\"{total_strategy_return:.2%}\",\n",
    "        'Total Buy & Hold Return': f\"{total_buy_hold_return:.2%}\",\n",
    "        'Strategy Volatility': f\"{strategy_vol:.2%}\",\n",
    "        'Buy & Hold Volatility': f\"{buy_hold_vol:.2%}\",\n",
    "        'Strategy Sharpe Ratio': f\"{strategy_sharpe:.3f}\",\n",
    "        'Buy & Hold Sharpe Ratio': f\"{buy_hold_sharpe:.3f}\",\n",
    "        'Number of Trades': num_trades,\n",
    "        'Win Rate': f\"{win_rate:.2%}\",\n",
    "        'Average Win': f\"{avg_win:.3%}\",\n",
    "        'Average Loss': f\"{avg_loss:.3%}\",\n",
    "        'Average Holding Period': f\"{avg_holding_period:.1f} days\" if not pd.isna(avg_holding_period) else \"N/A\",\n",
    "        'Max Strategy Drawdown': f\"{max_strategy_dd:.2%}\",\n",
    "        'Max Buy & Hold Drawdown': f\"{max_bh_dd:.2%}\",\n",
    "        'Excess Return': f\"{(total_strategy_return - total_buy_hold_return):.2%}\",\n",
    "        'Signal Strength Range': f\"{signal_strength_stats['min']:.0f} to {signal_strength_stats['max']:.0f}\"\n",
    "    }\n",
    "    \n",
    "    return results, df\n",
    "\n",
    "# def plot_results_mtf(df):\n",
    "#     \"\"\"Create visualization of multi-timeframe strategy performance, showing only cumulative returns\"\"\"\n",
    "    \n",
    "#     plt.figure(figsize=(16, 6))\n",
    "    \n",
    "#     # Plot cumulative returns\n",
    "#     plt.plot(df.index, df['cumulative_strategy_return'], label='Multi-Timeframe Strategy', linewidth=2, color='blue')\n",
    "#     plt.plot(df.index, df['cumulative_buy_hold_return'], label='Buy & Hold', linewidth=2, color='orange')\n",
    "#     plt.title('Cumulative Returns Comparison')\n",
    "#     plt.xlabel('Date')\n",
    "#     plt.ylabel('Cumulative Return')\n",
    "#     plt.legend()\n",
    "#     plt.grid(True, alpha=0.3)\n",
    "    \n",
    "#     plt.tight_layout()\n",
    "#     plt.show()\n",
    "def plot_results_mtf(df):\n",
    "    \"\"\"Create visualization of multi-timeframe strategy performance - Returns only\"\"\"\n",
    "    \n",
    "    fig, ax = plt.subplots(1, 1, figsize=(14, 8))\n",
    "    \n",
    "    # Plot: Cumulative Returns\n",
    "    ax.plot(df.index, df['cumulative_strategy_return'], label='Multi-Timeframe Strategy (EWMA)', \n",
    "            linewidth=2.5, color='blue')\n",
    "    ax.plot(df.index, df['cumulative_buy_hold_return'], label='Buy & Hold', \n",
    "            linewidth=2.5, color='orange')\n",
    "    \n",
    "    ax.set_title('Enhanced Multi-Timeframe Strategy vs Buy & Hold - Cumulative Returns', \n",
    "                 fontsize=16, fontweight='bold')\n",
    "    ax.set_xlabel('Date', fontsize=12)\n",
    "    ax.set_ylabel('Cumulative Return', fontsize=12)\n",
    "    ax.legend(fontsize=12)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Add performance text box\n",
    "    strategy_return = df['cumulative_strategy_return'].iloc[-1]\n",
    "    bh_return = df['cumulative_buy_hold_return'].iloc[-1]\n",
    "    excess_return = strategy_return - bh_return\n",
    "    \n",
    "    textstr = f'Strategy Return: {strategy_return:.1%}\\nBuy & Hold Return: {bh_return:.1%}\\nExcess Return: {excess_return:.1%}'\n",
    "    props = dict(boxstyle='round', facecolor='wheat', alpha=0.8)\n",
    "    ax.text(0.02, 0.98, textstr, transform=ax.transAxes, fontsize=11,\n",
    "            verticalalignment='top', bbox=props)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"Returns\", dpi=300, bbox_inches='tight') # You can adjust dpi and bbox_inches as needed\n",
    "    plt.show()\n",
    "\n",
    "# Main execution function\n",
    "def run_multitimeframe_strategy(merged3):\n",
    "    \"\"\"Main function to run the complete multi-timeframe strategy analysis\"\"\"\n",
    "    \n",
    "    print(\"=\"*70)\n",
    "    print(\"MULTI-TIMEFRAME CONFIRMATION TRADING STRATEGY BACKTEST\")\n",
    "    print(\"=\"*70)\n",
    "    \n",
    "    # Run strategy\n",
    "    print(\"\\nRunning multi-timeframe confirmation strategy...\")\n",
    "    results_df = multi_timeframe_strategy(merged3)\n",
    "    \n",
    "    # Calculate performance\n",
    "    print(\"\\nCalculating performance metrics...\")\n",
    "    performance, results_df = calculate_performance_metrics_mtf(results_df)\n",
    "    \n",
    "    if performance is None:\n",
    "        return None, None\n",
    "    \n",
    "    # Display results\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"MULTI-TIMEFRAME STRATEGY PERFORMANCE SUMMARY\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    for metric, value in performance.items():\n",
    "        print(f\"{metric:<30}: {value}\")\n",
    "    \n",
    "    # Additional analysis\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"SIGNAL ANALYSIS\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    signal_counts = results_df['total_signal_strength'].value_counts().sort_index()\n",
    "    print(\"Signal Strength Distribution:\")\n",
    "    for strength, count in signal_counts.items():\n",
    "        print(f\"  Signal {strength:2.0f}: {count:4d} days ({count/len(results_df)*100:.1f}%)\")\n",
    "    \n",
    "    entry_signals = results_df[results_df['entry_signal'] != 0]\n",
    "    if len(entry_signals) > 0:\n",
    "        print(f\"\\nTrade Entry Analysis:\")\n",
    "        print(f\"Long entries:  {len(entry_signals[entry_signals['entry_signal'] == 1])}\")\n",
    "        print(f\"Short entries: {len(entry_signals[entry_signals['entry_signal'] == -1])}\")\n",
    "    \n",
    "    # Create plots\n",
    "    print(\"\\nGenerating performance charts...\")\n",
    "    plot_results_mtf(results_df)\n",
    "    \n",
    "    return results_df, performance\n",
    "\n",
    "# Example usage:\n",
    "# results_df, performance = run_multitimeframe_strategy(merged3)\n",
    "\n",
    "# To run the strategy, uncomment the line below:\n",
    "# results_df, performance = run_multitimeframe_strategy(merged3)"
   ]
  },

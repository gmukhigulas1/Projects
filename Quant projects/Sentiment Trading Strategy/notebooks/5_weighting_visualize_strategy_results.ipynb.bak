   "source": [
    "# Process S&P 100 weighted sentiment\n",
    "df = pd.read_csv('sp100_sentiment_with_weighted.csv')\n",
    "\n",
    "# Filter valid rows\n",
    "df_valid = df[df['created_utc'].notna() & df['W_sentiment'].notna()].copy()\n",
    "\n",
    "# Convert timestamps and extract date\n",
    "df_valid['created_utc'] = pd.to_datetime(df_valid['created_utc'])\n",
    "df_valid['Date'] = df_valid['created_utc'].dt.date\n",
    "df_valid['sentiment_compound'] = pd.to_numeric(df_valid['W_sentiment'], errors='coerce').fillna(0)\n",
    "\n",
    "# Aggregate: mean sentiment per day\n",
    "sentiment = df_valid.groupby('Date')['sentiment_compound'].mean().reset_index()\n",
    "sentiment['Date'] = pd.to_datetime(sentiment['Date'])\n",
    "sentiment['sentiment_ma7'] = sentiment['sentiment_compound'].rolling(window=7, min_periods=1).mean()\n",
    "\n",
    "print(f\"S&P 100 data: {len(sentiment)} days\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "51e2d929",
   "metadata": {},
   "source": [
    "## Regression Analysis\n",
    "\n",
    "Run regression models to quantify the relationship between sentiment and returns."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "820dc300",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Regression analysis\n",
    "# Check for missing values and convert to numeric\n",
    "merged3['^OEX'] = pd.to_numeric(merged3['^OEX'], errors='coerce')\n",
    "merged3['weighted_sentiment'] = pd.to_numeric(merged3['weighted_sentiment'], errors='coerce')\n",
    "merged3['sentiment_ewma30'] = pd.to_numeric(merged3['sentiment_ewma30'], errors='coerce')\n",
    "\n",
    "# Drop rows with NaN values in relevant columns\n",
    "merged3_clean = merged3.dropna(subset=['^OEX', 'weighted_sentiment', 'sentiment_ewma30'])\n",
    "\n",
    "# Simple regression: Daily Returns ~ weighted_sentiment\n",
    "X1 = sm.add_constant(merged3_clean['weighted_sentiment'])\n",
    "y1 = merged3_clean['^OEX']\n",
    "model1 = sm.OLS(y1, X1).fit()\n",
    "print(\"Simple Regression Results (^OEX ~ weighted_sentiment):\")\n",
    "print(model1.summary())\n",
    "\n",
    "# Simple regression: Daily Returns ~ sentiment_ewma30\n",
    "X2 = sm.add_constant(merged3_clean['sentiment_ewma30'])\n",
    "y2 = merged3_clean['^OEX']\n",
    "model2 = sm.OLS(y2, X2).fit()\n",
    "print(\"\\nSimple Regression Results (^OEX ~ sentiment_ewma30):\")\n",
    "print(model2.summary())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b63186dc",
   "metadata": {},
   "source": [
    "## Merge S&P 100 Sentiment with Market Data\n",
    "\n",
    "Combine sentiment data with market returns for analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c44a7d5b-e105-461a-9ac9-b40b4b2bcc47",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge S&P 100 sentiment with market data\n",
    "sentiment_indexed = sentiment.set_index('Date')\n",
    "merged = pd.merge(close, sentiment_indexed, left_on='Date', right_index=True, how='inner')\n",
    "print(f\"Merged data: {len(merged)} rows\")\n",
    "merged.head(10)"
   ]

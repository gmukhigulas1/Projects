    "# Run annual analysis for all years\n",
    "annual_results = analyze_annual_performance(merged3, start_year=2015, end_year=2025)\n",
    "\n",
    "# Convert to DataFrame for easier analysis\n",
    "annual_df = get_annual_summary_dataframe(annual_results)\n",
    "print(\"\\nAnnual Summary DataFrame:\")\n",
    "print(annual_df)\n",
    "\n",
    "# Create visualization\n",
    "plot_annual_performance(annual_results)"
   ]

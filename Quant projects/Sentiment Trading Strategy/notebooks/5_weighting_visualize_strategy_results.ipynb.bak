   "outputs": [],
   "source": [
    "def analyze_annual_performance(merged3, start_year=2015, end_year=2025):\n",
    "    \"\"\"\n",
    "    Analyze strategy performance year by year with proper warm-up periods\n",
    "    \n",
    "    Parameters:\n",
    "    merged3: DataFrame with your trading data\n",
    "    start_year: int, first year to analyze (default: 2015)\n",
    "    end_year: int, last year to analyze (default: 2025)\n",
    "    \"\"\"\n",
    "    annual_results = {}\n",
    "    \n",
    "    print(\"=\"*80)\n",
    "    print(\"ANNUAL STRATEGY PERFORMANCE ANALYSIS\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    for year in range(start_year, end_year + 1):\n",
    "        print(f\"\\n{'='*50}\")\n",
    "        print(f\"ANALYZING YEAR: {year}\")\n",
    "        print(f\"{'='*50}\")\n",
    "        \n",
    "        # Define date range for the year\n",
    "        start_date = f\"{year}-01-01\"\n",
    "        end_date = f\"{year}-12-31\"\n",
    "        \n",
    "        # For 2025, use actual end date of your data\n",
    "        if year == 2025:\n",
    "            end_date = \"2025-05-16\"  # Your actual data end date\n",
    "        \n",
    "        try:\n",
    "            # Run strategy with warm-up period (uses previous year's data for calculations)\n",
    "            year_results, year_performance = run_realistic_strategy_with_warmup(\n",
    "                merged3,\n",
    "                start_date=start_date,\n",
    "                end_date=end_date,\n",
    "                warmup_days=26 # Use 1 year of warm-up data\n",
    "            )\n",
    "            \n",
    "            if year_performance:\n",
    "                annual_results[year] = {\n",
    "                    'performance': year_performance,\n",
    "                    'data': year_results,\n",
    "                    'start_date': start_date,\n",
    "                    'end_date': end_date\n",
    "                }\n",
    "                \n",
    "                # Print key metrics for this year\n",
    "                print(f\"\\nKey Results for {year}:\")\n",
    "                print(f\"Strategy Return: {year_performance['Total Strategy Return']}\")\n",
    "                print(f\"Buy & Hold Return: {year_performance['Total Buy & Hold Return']}\")\n",
    "                print(f\"Excess Return: {year_performance['Excess Return']}\")\n",
    "                print(f\"Number of Trades: {year_performance['Number of Trades']}\")\n",
    "                print(f\"Win Rate: {year_performance['Win Rate']}\")\n",
    "                \n",
    "            else:\n",
    "                print(f\"No valid results for {year}\")\n",
    "                annual_results[year] = None\n",
    "                \n",
    "        except Exception as e:\n",
    "            print(f\"Error analyzing year {year}: {e}\")\n",
    "            annual_results[year] = None\n",
    "    \n",
    "    # Create summary table\n",
    "    print(f\"\\n{'='*100}\")\n",
    "    print(\"ANNUAL PERFORMANCE SUMMARY\")\n",
    "    print(f\"{'='*100}\")\n",
    "    \n",
    "    # Header\n",
    "    print(f\"{'Year':<6} {'Strategy':<12} {'Buy&Hold':<12} {'Excess':<10} {'Trades':<8} {'Win Rate':<10} {'Sharpe':<8}\")\n",
    "    print(\"-\" * 100)\n",
    "    \n",
    "    # Results for each year\n",
    "    for year in range(start_year, end_year + 1):\n",
    "        if annual_results[year] and annual_results[year]['performance']:\n",
    "            perf = annual_results[year]['performance']\n",
    "            \n",
    "            strategy_ret = perf['Total Strategy Return']\n",
    "            bh_ret = perf['Total Buy & Hold Return'] \n",
    "            excess_ret = perf['Excess Return']\n",
    "            trades = perf['Number of Trades']\n",
    "            win_rate = perf['Win Rate']\n",
    "            sharpe = perf['Strategy Sharpe Ratio']\n",
    "            \n",
    "            print(f\"{year:<6} {strategy_ret:<12} {bh_ret:<12} {excess_ret:<10} {trades:<8} {win_rate:<10} {sharpe:<8}\")\n",
    "        else:\n",
    "            print(f\"{year:<6} {'No Data':<12} {'No Data':<12} {'No Data':<10} {'0':<8} {'No Data':<10} {'No Data':<8}\")\n",
    "    \n",
    "    return annual_results\n",
    "\n",
    "def get_annual_summary_dataframe(annual_results):\n",
    "    \"\"\"\n",
    "    Convert annual results to a pandas DataFrame for easy analysis\n",
    "    \"\"\"\n",
    "    summary_data = []\n",
    "    \n",
    "    for year, result in annual_results.items():\n",
    "        if result and result['performance']:\n",
    "            perf = result['performance']\n",
    "            \n",
    "            # Extract numeric values (remove % signs)\n",
    "            strategy_ret = float(perf['Total Strategy Return'].replace('%', '')) / 100\n",
    "            bh_ret = float(perf['Total Buy & Hold Return'].replace('%', '')) / 100\n",
    "            excess_ret = float(perf['Excess Return'].replace('%', '')) / 100\n",
    "            win_rate = float(perf['Win Rate'].replace('%', '')) / 100\n",
    "            sharpe = float(perf['Strategy Sharpe Ratio'])\n",
    "            \n",
    "            summary_data.append({\n",
    "                'Year': year,\n",
    "                'Strategy_Return': strategy_ret,\n",
    "                'BuyHold_Return': bh_ret,\n",
    "                'Excess_Return': excess_ret,\n",
    "                'Number_of_Trades': perf['Number of Trades'],\n",
    "                'Win_Rate': win_rate,\n",
    "                'Strategy_Sharpe': sharpe,\n",
    "                'Avg_Holding_Period': perf['Average Holding Period']\n",
    "            })\n",
    "    \n",
    "    return pd.DataFrame(summary_data)\n",
    "\n",
    "def plot_annual_performance(annual_results):\n",
    "    \"\"\"\n",
    "    Create visualization of annual performance including cumulative returns\n",
    "    \"\"\"\n",
    "    # Extract data for plotting\n",
    "    years = []\n",
    "    strategy_returns = []\n",
    "    bh_returns = []\n",
    "    \n",
    "    for year, result in annual_results.items():\n",
    "        if result and result['performance']:\n",
    "            years.append(year)\n",
    "            strategy_returns.append(float(result['performance']['Total Strategy Return'].replace('%', '')))\n",
    "            bh_returns.append(float(result['performance']['Total Buy & Hold Return'].replace('%', '')))\n",
    "    \n",
    "    # Calculate cumulative returns\n",
    "    cumulative_strategy = []\n",
    "    cumulative_bh = []\n",
    "    \n",
    "    cum_strat = 1.0\n",
    "    cum_bh = 1.0\n",
    "    \n",
    "    for strat_ret, bh_ret in zip(strategy_returns, bh_returns):\n",
    "        cum_strat *= (1 + strat_ret/100)\n",
    "        cum_bh *= (1 + bh_ret/100)\n",
    "        cumulative_strategy.append(cum_strat)\n",
    "        cumulative_bh.append(cum_bh)\n",
    "    \n",
    "    # Convert to percentage returns for display\n",
    "    cumulative_strategy_pct = [(x-1)*100 for x in cumulative_strategy]\n",
    "    cumulative_bh_pct = [(x-1)*100 for x in cumulative_bh]\n",
    "    \n",
    "    # Chart 1: Annual Returns Comparison\n",
    "    fig1, ax1 = plt.subplots(1, 1, figsize=(12, 6))\n",
    "    \n",
    "    x = np.arange(len(years))\n",
    "    width = 0.35\n",
    "    \n",
    "    ax1.bar(x - width/2, strategy_returns, width, label='Strategy', color='green', alpha=0.7)\n",
    "    ax1.bar(x + width/2, bh_returns, width, label='Buy & Hold', color='orange', alpha=0.7)\n",
    "    \n",
    "    ax1.set_xlabel('Year')\n",
    "    ax1.set_ylabel('Annual Return (%)')\n",
    "    ax1.set_title('Annual Returns: Strategy vs Buy & Hold')\n",
    "    ax1.set_xticks(x)\n",
    "    ax1.set_xticklabels(years)\n",
    "    ax1.legend()\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"Chart1_Annual_Returns.png\", dpi=300, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    \n",
    "    # Chart 2: Excess Returns\n",
    "    fig2, ax2 = plt.subplots(1, 1, figsize=(12, 6))\n",
    "    \n",
    "    excess_returns = [s - b for s, b in zip(strategy_returns, bh_returns)]\n",
    "    colors = ['green' if x > 0 else 'red' for x in excess_returns]\n",
    "    \n",
    "    ax2.bar(years, excess_returns, color=colors, alpha=0.7)\n",
    "    ax2.axhline(y=0, color='black', linestyle='-', linewidth=0.5)\n",
    "    ax2.set_xlabel('Year')\n",
    "    ax2.set_ylabel('Excess Return (%)')\n",
    "    ax2.set_title('Annual Excess Returns (Strategy - Buy & Hold)')\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"Chart2_Excess_Returns.png\", dpi=300, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    \n",
    "    # Chart 3: Cumulative Returns with delimiters and numbers on buy & hold line\n",
    "    fig3, ax3 = plt.subplots(1, 1, figsize=(15, 10))\n",
    "    \n",
    "    # Plot lines with markers\n",
    "    ax3.plot(years, cumulative_strategy_pct, marker='o', linewidth=2.5, \n",
    "             label='Strategy Cumulative', color='green', markersize=6)\n",
    "    ax3.plot(years, cumulative_bh_pct, marker='s', linewidth=2.5, \n",
    "             label='Buy & Hold Cumulative', color='orange', markersize=6)\n",
    "    \n",
    "    ax3.set_yscale('log')\n",
    "    ax3.set_xlabel('Year')\n",
    "    ax3.set_ylabel('Cumulative Return (%)')\n",
    "    ax3.set_title('Total Period Returns - Cumulative Performance (Logarithmic Scale)')\n",
    "    ax3.legend()\n",
    "    ax3.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Add vertical delimiters (year separators)\n",
    "    for i, year in enumerate(years[:-1]):  # Don't add delimiter after last year\n",
    "        ax3.axvline(x=year + 0.5, color='gray', linestyle='--', alpha=0.5, linewidth=0.8)\n",
    "    \n",
    "    # Add numbers on the strategy line (starting from first point)\n",
    "    for i, (year, cum_strat_pct) in enumerate(zip(years, cumulative_strategy_pct)):\n",
    "        if i % 2 == 0:  # Annotate every other year starting from first\n",
    "            # Format numbers with thousand delimiter\n",
    "            if abs(cum_strat_pct) >= 1000:\n",
    "                formatted_value = f'{cum_strat_pct:,.0f}%'\n",
    "            else:\n",
    "                formatted_value = f'{cum_strat_pct:.0f}%'\n",
    "            \n",
    "            ax3.annotate(formatted_value, \n",
    "                        (year, cum_strat_pct), \n",
    "                        textcoords=\"offset points\", \n",
    "                        xytext=(0,15), \n",
    "                        ha='center', fontsize=9, color='green', fontweight='bold')\n",
    "    \n",
    "    # Add numbers on the buy & hold line (starting from second point)\n",
    "    for i, (year, cum_bh_pct) in enumerate(zip(years, cumulative_bh_pct)):\n",
    "        if i % 2 == 1 and i >= 1:  # Annotate every other year starting from second point\n",
    "            # Format numbers with thousand delimiter\n",
    "            if abs(cum_bh_pct) >= 1000:\n",
    "                formatted_value = f'{cum_bh_pct:,.0f}%'\n",
    "            else:\n",
    "                formatted_value = f'{cum_bh_pct:.0f}%'\n",
    "            \n",
    "            ax3.annotate(formatted_value, \n",
    "                        (year, cum_bh_pct), \n",
    "                        textcoords=\"offset points\", \n",
    "                        xytext=(0,15), \n",
    "                        ha='center', fontsize=9, color='orange', fontweight='bold')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"Chart3_Cumulative_Returns.png\", dpi=300, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    \n",
    "    # Print clean summary statistics\n",
    "    final_strategy_return = cumulative_strategy_pct[-1]\n",
    "    final_bh_return = cumulative_bh_pct[-1]\n",
    "    \n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(\"CUMULATIVE PERFORMANCE SUMMARY\")\n",
    "    print(f\"{'='*60}\")\n",
    "    print(f\"Strategy total return: {final_strategy_return:.1f}%\")\n",
    "    print(f\"Buy & hold total return: {final_bh_return:.1f}%\")\n",
    "    print(f\"Outperformance: {final_strategy_return - final_bh_return:.1f} percentage points\")\n",
    "    print(f\"\\nChart files saved:\")\n",
    "    print(\"- Chart1_Annual_Returns.png\")\n",
    "    print(\"- Chart2_Excess_Returns.png\") \n",
    "    print(\"- Chart3_Cumulative_Returns.png\")"
   ]

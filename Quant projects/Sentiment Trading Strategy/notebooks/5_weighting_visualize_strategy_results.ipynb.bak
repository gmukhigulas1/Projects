   "source": [
    "# Create various moving averages for weighted_sentiment\n",
    "merged3['sentiment_ma3'] = merged3['weighted_sentiment'].rolling(window=3, min_periods=1).mean()\n",
    "merged3['sentiment_ma5'] = merged3['weighted_sentiment'].rolling(window=5, min_periods=1).mean()\n",
    "merged3['sentiment_ma10'] = merged3['weighted_sentiment'].rolling(window=10, min_periods=1).mean()\n",
    "merged3['sentiment_ma14'] = merged3['weighted_sentiment'].rolling(window=14, min_periods=1).mean()\n",
    "merged3['sentiment_ma21'] = merged3['weighted_sentiment'].rolling(window=21, min_periods=1).mean()\n",
    "merged3['sentiment_ma30'] = merged3['weighted_sentiment'].rolling(window=30, min_periods=1).mean()\n",
    "\n",
    "# Exponentially Weighted Moving Averages (EWMA)\n",
    "merged3['sentiment_ewma3'] = merged3['weighted_sentiment'].ewm(span=3).mean()\n",
    "merged3['sentiment_ewma7'] = merged3['weighted_sentiment'].ewm(span=7).mean()\n",
    "merged3['sentiment_ewma14'] = merged3['weighted_sentiment'].ewm(span=14).mean()\n",
    "merged3['sentiment_ewma21'] = merged3['weighted_sentiment'].ewm(span=21).mean()\n",
    "merged3['sentiment_ewma30'] = merged3['weighted_sentiment'].ewm(span=30).mean()\n",
    "merged3['sentiment_ewma40'] = merged3['weighted_sentiment'].ewm(span=40).mean()\n",
    "merged3['sentiment_ewma50'] = merged3['weighted_sentiment'].ewm(span=50).mean()\n",
    "merged3['sentiment_ewma60'] = merged3['weighted_sentiment'].ewm(span=60).mean()\n",
    "merged3['sentiment_ewma90'] = merged3['weighted_sentiment'].ewm(span=90).mean()\n",
    "merged3['sentiment_ewma100'] = merged3['weighted_sentiment'].ewm(span=100).mean()\n",
    "merged3['sentiment_ewma250'] = merged3['weighted_sentiment'].ewm(span=250).mean()\n",
    "\n",
    "# Custom EWMA with specific decay rates\n",
    "merged3['sentiment_ewma_custom'] = merged3['weighted_sentiment'].ewm(alpha=0.4).mean()\n",
    "\n",
    "# Momentum indicators (rate of change)\n",
    "merged3['sentiment_momentum3'] = merged3['weighted_sentiment'] - merged3['sentiment_ma3'].shift(3)\n",
    "merged3['sentiment_momentum7'] = merged3['weighted_sentiment'] - merged3['sentiment_ma7'].shift(7)\n",
    "\n",
    "# Sentiment volatility (rolling standard deviation)\n",
    "merged3['sentiment_vol7'] = merged3['weighted_sentiment'].rolling(window=7).std()\n",
    "merged3['sentiment_vol14'] = merged3['weighted_sentiment'].rolling(window=14).std()\n",
    "\n",
    "# Z-score normalization (sentiment relative to recent history)\n",
    "merged3['sentiment_zscore7'] = (merged3['weighted_sentiment'] - merged3['sentiment_ma7']) / merged3['sentiment_vol7']\n",
    "merged3['sentiment_zscore14'] = (merged3['weighted_sentiment'] - merged3['sentiment_ma14']) / merged3['sentiment_vol14']\n",
    "\n",
    "# Display the new columns\n",
    "print(\"New columns added:\")\n",
    "print(merged3.columns.tolist())\n",
    "\n",
    "# Quick correlation analysis with S&P 100 returns\n",
    "print(\"\\nCorrelation with % Change (S&P 100 returns):\")\n",
    "correlation_cols = ['weighted_sentiment', 'sentiment_ma7', 'sentiment_ma3', 'sentiment_ma5', \n",
    "                   'sentiment_ma10', 'sentiment_ma14', 'sentiment_ma21', 'sentiment_ma30',\n",
    "                   'sentiment_ewma3', 'sentiment_ewma7', 'sentiment_ewma14','sentiment_ewma21','sentiment_ewma30','sentiment_ewma40','sentiment_ewma50',\n",
    "                    'sentiment_ewma60','sentiment_ewma90','sentiment_ewma100','sentiment_ewma250',\n",
    "                   'sentiment_momentum3', 'sentiment_momentum7', 'sentiment_zscore7']\n",
    "\n",
    "for col in correlation_cols:\n",
    "    if col in merged3.columns:\n",
    "        corr = merged3['^OEX'].corr(merged3[col])\n",
    "        print(f\"{col}: {corr:.6f}\")\n",
    "\n",
    "# Optional: Save the enhanced dataset\n",
    "# merged3.to_csv('enhanced_sentiment_data.csv', index=False)"
   ]
  },

   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from datetime import datetime\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "def run_full_strategy_once(merged3):\n",
    "    \"\"\"\n",
    "    Run the strategy ONCE on the full dataset to get consistent signals\n",
    "    \"\"\"\n",
    "    print(\"=\"*80)\n",
    "    print(\"RUNNING STRATEGY ON FULL DATASET FOR CONSISTENT ANALYSIS\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    # Calculate ma30 overall median from full dataset\n",
    "    ma30_overall_median = merged3['sentiment_ewma30'].median()\n",
    "    print(f\"Using MA30 overall median from full dataset: {ma30_overall_median:.4f}\")\n",
    "    \n",
    "    # Run strategy on full dataset\n",
    "    results_df = multi_timeframe_strategy_realistic(merged3, ma30_overall_median)\n",
    "    \n",
    "    # Calculate full performance for verification\n",
    "    full_performance, results_df = calculate_performance_metrics_realistic(results_df)\n",
    "    \n",
    "    print(\"\\nFULL DATASET PERFORMANCE:\")\n",
    "    print(\"-\" * 50)\n",
    "    for metric, value in full_performance.items():\n",
    "        print(f\"{metric:<30}: {value}\")\n",
    "    \n",
    "    return results_df, full_performance\n",
    "\n",
    "def attribute_trades_to_years(results_df):\n",
    "    \"\"\"\n",
    "    Attribute each trade to the year it was CLOSED (realized)\n",
    "    \"\"\"\n",
    "    # Find all exit signals (where trades are closed and returns realized)\n",
    "    exit_trades = results_df[results_df['exit_signal'] != 0].copy()\n",
    "    \n",
    "    if len(exit_trades) == 0:\n",
    "        print(\"No trades found!\")\n",
    "        return {}\n",
    "    \n",
    "    # Group trades by year of exit\n",
    "    exit_trades['exit_year'] = exit_trades.index.year\n",
    "    trades_by_year = {}\n",
    "    \n",
    "    for year, year_trades in exit_trades.groupby('exit_year'):\n",
    "        trades_by_year[year] = {\n",
    "            'trades': year_trades,\n",
    "            'num_trades': len(year_trades),\n",
    "            'total_strategy_return': year_trades['strategy_return'].sum(),\n",
    "            'trade_returns': year_trades['strategy_return'].tolist()\n",
    "        }\n",
    "    \n",
    "    return trades_by_year\n",
    "\n",
    "def calculate_annual_buy_hold_returns(results_df):\n",
    "    \"\"\"\n",
    "    Calculate buy & hold returns for each calendar year\n",
    "    \"\"\"\n",
    "    annual_bh_returns = {}\n",
    "    \n",
    "    for year in range(results_df.index.year.min(), results_df.index.year.max() + 1):\n",
    "        year_data = results_df[results_df.index.year == year]\n",
    "        \n",
    "        if len(year_data) > 0:\n",
    "            # Calculate buy & hold return for the year\n",
    "            year_bh_return = (1 + year_data['buy_hold_return']).prod() - 1\n",
    "            annual_bh_returns[year] = year_bh_return\n",
    "        else:\n",
    "            annual_bh_returns[year] = 0.0\n",
    "    \n",
    "    return annual_bh_returns\n",
    "\n",
    "def analyze_annual_performance_consistent(merged3, start_year=None, end_year=None):\n",
    "    \"\"\"\n",
    "    Analyze annual performance by running strategy once and attributing trades to years\n",
    "    \"\"\"\n",
    "    print(\"=\"*80)\n",
    "    print(\"CONSISTENT ANNUAL PERFORMANCE ANALYSIS\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    # Step 1: Run strategy once on full dataset\n",
    "    results_df, full_performance = run_full_strategy_once(merged3)\n",
    "    \n",
    "    # Step 2: Attribute trades to years\n",
    "    print(\"\\nAttributing trades to years...\")\n",
    "    trades_by_year = attribute_trades_to_years(results_df)\n",
    "    \n",
    "    # Step 3: Calculate annual buy & hold returns\n",
    "    print(\"Calculating annual buy & hold returns...\")\n",
    "    annual_bh_returns = calculate_annual_buy_hold_returns(results_df)\n",
    "    \n",
    "    # Step 4: Determine year range\n",
    "    data_start_year = results_df.index.year.min()\n",
    "    data_end_year = results_df.index.year.max()\n",
    "    \n",
    "    if start_year is None:\n",
    "        start_year = data_start_year\n",
    "    if end_year is None:  \n",
    "        end_year = data_end_year\n",
    "    \n",
    "    print(f\"\\nAnalyzing years {start_year} to {end_year}\")\n",
    "    \n",
    "    # Step 5: Compile annual results\n",
    "    annual_results = {}\n",
    "    total_strategy_return_check = 0\n",
    "    total_trades_check = 0\n",
    "    \n",
    "    for year in range(start_year, end_year + 1):\n",
    "        if year in trades_by_year:\n",
    "            year_trades = trades_by_year[year]\n",
    "            strategy_return = year_trades['total_strategy_return']\n",
    "            num_trades = year_trades['num_trades']\n",
    "            trade_returns = year_trades['trade_returns']\n",
    "            \n",
    "            # Calculate statistics for this year's trades\n",
    "            win_rate = sum(1 for r in trade_returns if r > 0) / len(trade_returns) if trade_returns else 0\n",
    "            avg_win = np.mean([r for r in trade_returns if r > 0]) if any(r > 0 for r in trade_returns) else 0\n",
    "            avg_loss = np.mean([r for r in trade_returns if r < 0]) if any(r < 0 for r in trade_returns) else 0\n",
    "            \n",
    "        else:\n",
    "            strategy_return = 0.0\n",
    "            num_trades = 0\n",
    "            win_rate = 0\n",
    "            avg_win = 0\n",
    "            avg_loss = 0\n",
    "            trade_returns = []\n",
    "        \n",
    "        # Get buy & hold return for this year\n",
    "        bh_return = annual_bh_returns.get(year, 0.0)\n",
    "        \n",
    "        # Calculate excess return\n",
    "        excess_return = strategy_return - bh_return\n",
    "        \n",
    "        # Calculate volatility if there are trades\n",
    "        if len(trade_returns) > 1:\n",
    "            strategy_vol = np.std(trade_returns) * np.sqrt(252)  # Annualized\n",
    "        else:\n",
    "            strategy_vol = 0\n",
    "        \n",
    "        # Get year data for additional metrics\n",
    "        year_data = results_df[results_df.index.year == year]\n",
    "        year_bh_vol = year_data['buy_hold_return'].std() * np.sqrt(252) if len(year_data) > 1 else 0\n",
    "        \n",
    "        # Calculate Sharpe ratios\n",
    "        strategy_sharpe = (strategy_return * 252) / strategy_vol if strategy_vol > 0 else 0\n",
    "        bh_sharpe = (bh_return * 252) / year_bh_vol if year_bh_vol > 0 else 0\n",
    "        \n",
    "        annual_results[year] = {\n",
    "            'Strategy_Return': strategy_return,\n",
    "            'BuyHold_Return': bh_return,\n",
    "            'Excess_Return': excess_return,\n",
    "            'Number_of_Trades': num_trades,\n",
    "            'Win_Rate': win_rate,\n",
    "            'Average_Win': avg_win,\n",
    "            'Average_Loss': avg_loss,\n",
    "            'Strategy_Volatility': strategy_vol,\n",
    "            'BuyHold_Volatility': year_bh_vol,\n",
    "            'Strategy_Sharpe': strategy_sharpe,\n",
    "            'BuyHold_Sharpe': bh_sharpe,\n",
    "            'Trade_Returns': trade_returns\n",
    "        }\n",
    "        \n",
    "        # Add to totals for verification\n",
    "        total_strategy_return_check += strategy_return\n",
    "        total_trades_check += num_trades\n",
    "    \n",
    "    # Step 6: Print summary table\n",
    "    print(f\"\\n{'='*120}\")\n",
    "    print(\"ANNUAL PERFORMANCE BREAKDOWN\")\n",
    "    print(f\"{'='*120}\")\n",
    "    \n",
    "    print(f\"{'Year':<6} {'Strategy':<12} {'Buy&Hold':<12} {'Excess':<10} {'Trades':<8} {'Win Rate':<10} {'Avg Win':<10} {'Avg Loss':<10}\")\n",
    "    print(\"-\" * 120)\n",
    "    \n",
    "    for year in range(start_year, end_year + 1):\n",
    "        result = annual_results[year]\n",
    "        print(f\"{year:<6} {result['Strategy_Return']:<12.2%} {result['BuyHold_Return']:<12.2%} \"\n",
    "              f\"{result['Excess_Return']:<10.2%} {result['Number_of_Trades']:<8} \"\n",
    "              f\"{result['Win_Rate']:<10.2%} {result['Average_Win']:<10.3%} {result['Average_Loss']:<10.3%}\")\n",
    "    \n",
    "    # Step 7: Verification\n",
    "    print(f\"\\n{'='*80}\")\n",
    "    print(\"VERIFICATION AGAINST FULL DATASET\")\n",
    "    print(f\"{'='*80}\")\n",
    "    \n",
    "    full_strategy_return = float(full_performance['Total Strategy Return'].replace('%', '')) / 100\n",
    "    full_trades = full_performance['Number of Trades']\n",
    "    \n",
    "    print(f\"Full dataset strategy return:     {full_strategy_return:.4%}\")\n",
    "    print(f\"Sum of annual strategy returns:   {total_strategy_return_check:.4%}\")\n",
    "    print(f\"Difference:                       {abs(full_strategy_return - total_strategy_return_check):.6%}\")\n",
    "    print(f\"\")\n",
    "    print(f\"Full dataset number of trades:    {full_trades}\")\n",
    "    print(f\"Sum of annual trades:             {total_trades_check}\")\n",
    "    print(f\"Difference:                       {abs(full_trades - total_trades_check)}\")\n",
    "    \n",
    "    # Calculate compound effect\n",
    "    annual_compound_return = 1\n",
    "    for year in range(start_year, end_year + 1):\n",
    "        annual_compound_return *= (1 + annual_results[year]['Strategy_Return'])\n",
    "    annual_compound_return -= 1\n",
    "    \n",
    "    print(f\"\")\n",
    "    print(f\"Compound return from annual:      {annual_compound_return:.4%}\")\n",
    "    print(f\"Full dataset compound return:     {full_strategy_return:.4%}\")\n",
    "    \n",
    "    return annual_results, results_df, full_performance\n",
    "\n",
    "def plot_annual_performance_consistent(annual_results, save_plots=True):\n",
    "    \"\"\"\n",
    "    Create comprehensive visualization of annual performance\n",
    "    \"\"\"\n",
    "    years = list(annual_results.keys())\n",
    "    strategy_returns = [annual_results[year]['Strategy_Return'] for year in years]\n",
    "    bh_returns = [annual_results[year]['BuyHold_Return'] for year in years]\n",
    "    excess_returns = [annual_results[year]['Excess_Return'] for year in years]\n",
    "    num_trades = [annual_results[year]['Number_of_Trades'] for year in years]\n",
    "    \n",
    "    # Create comprehensive plot\n",
    "    fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(16, 12))\n",
    "    \n",
    "    # Plot 1: Annual Returns Comparison\n",
    "    x = np.arange(len(years))\n",
    "    width = 0.35\n",
    "    \n",
    "    ax1.bar(x - width/2, [r*100 for r in strategy_returns], width, \n",
    "            label='Strategy', color='green', alpha=0.7)\n",
    "    ax1.bar(x + width/2, [r*100 for r in bh_returns], width, \n",
    "            label='Buy & Hold', color='orange', alpha=0.7)\n",
    "    \n",
    "    ax1.set_xlabel('Year')\n",
    "    ax1.set_ylabel('Annual Return (%)')\n",
    "    ax1.set_title('Annual Returns: Strategy vs Buy & Hold')\n",
    "    ax1.set_xticks(x)\n",
    "    ax1.set_xticklabels(years, rotation=45)\n",
    "    ax1.legend()\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Plot 2: Excess Returns\n",
    "    colors = ['green' if x > 0 else 'red' for x in excess_returns]\n",
    "    ax2.bar(years, [r*100 for r in excess_returns], color=colors, alpha=0.7)\n",
    "    ax2.axhline(y=0, color='black', linestyle='-', linewidth=0.5)\n",
    "    ax2.set_xlabel('Year')\n",
    "    ax2.set_ylabel('Excess Return (%)')\n",
    "    ax2.set_title('Annual Excess Returns (Strategy - Buy & Hold)')\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Plot 3: Number of Trades per Year\n",
    "    ax3.bar(years, num_trades, color='blue', alpha=0.7)\n",
    "    ax3.set_xlabel('Year')\n",
    "    ax3.set_ylabel('Number of Trades')\n",
    "    ax3.set_title('Trading Activity by Year')\n",
    "    ax3.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Plot 4: Cumulative Performance\n",
    "    cumulative_strategy = np.cumprod([1 + r for r in strategy_returns])\n",
    "    cumulative_bh = np.cumprod([1 + r for r in bh_returns])\n",
    "    \n",
    "    ax4.plot(years, cumulative_strategy, marker='o', linewidth=2.5, \n",
    "             label='Strategy', color='green')\n",
    "    ax4.plot(years, cumulative_bh, marker='s', linewidth=2.5, \n",
    "             label='Buy & Hold', color='orange')\n",
    "    ax4.set_xlabel('Year')\n",
    "    ax4.set_ylabel('Cumulative Value ($1 Start)')\n",
    "    ax4.set_title('Cumulative Performance Over Time')\n",
    "    ax4.legend()\n",
    "    ax4.grid(True, alpha=0.3)\n",
    "    ax4.set_yscale('log')  # Log scale for better visualization\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    \n",
    "    if save_plots:\n",
    "        plt.savefig(\"Consistent_Annual_Performance.png\", dpi=300, bbox_inches='tight')\n",
    "    \n",
    "    plt.show()\n",
    "    \n",
    "    # Print summary statistics\n",
    "    avg_strategy_return = np.mean(strategy_returns)\n",
    "    avg_bh_return = np.mean(bh_returns)\n",
    "    avg_excess_return = np.mean(excess_returns)\n",
    "    \n",
    "    strategy_wins = sum(1 for r in strategy_returns if r > 0)\n",
    "    excess_wins = sum(1 for r in excess_returns if r > 0)\n",
    "    \n",
    "    total_trades = sum(num_trades)\n",
    "    \n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(\"SUMMARY STATISTICS\")\n",
    "    print(f\"{'='*60}\")\n",
    "    print(f\"Average annual strategy return:   {avg_strategy_return:.2%}\")\n",
    "    print(f\"Average annual buy & hold return: {avg_bh_return:.2%}\")\n",
    "    print(f\"Average annual excess return:     {avg_excess_return:.2%}\")\n",
    "    print(f\"Years with positive strategy:     {strategy_wins}/{len(years)} ({strategy_wins/len(years):.1%})\")\n",
    "    print(f\"Years with positive excess:       {excess_wins}/{len(years)} ({excess_wins/len(years):.1%})\")\n",
    "    print(f\"Total trades across all years:    {total_trades}\")\n",
    "    \n",
    "    return fig\n",
    "\n",
    "# Convenience function to run the complete analysis\n",
    "def run_complete_annual_analysis(merged3, start_year=None, end_year=None, create_plots=True):\n",
    "    \"\"\"\n",
    "    Run complete annual analysis with consistent methodology\n",
    "    \"\"\"\n",
    "    # Run the analysis\n",
    "    annual_results, results_df, full_performance = analyze_annual_performance_consistent(\n",
    "        merged3, start_year, end_year\n",
    "    )\n",
    "    \n",
    "    # Create plots if requested\n",
    "    if create_plots:\n",
    "        plot_annual_performance_consistent(annual_results)\n",
    "    \n",
    "    # Return results for further analysis\n",
    "    return annual_results, results_df, full_performance\n",
    "\n",
    "# Usage example:\n",
    "# annual_results, full_results_df, full_perf = run_complete_annual_analysis(merged3)"
   ]
  },

{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "90e39adf",
   "metadata": {},
   "source": [
    "# Weighting & Visualize Strategy Results\n",
    "\n",
    "This notebook:\n",
    "1. Loads sentiment and market data\n",
    "2. Creates weighted sentiment metrics\n",
    "3. Computes technical indicators (moving averages, EWMA, momentum)\n",
    "4. Analyzes correlation between sentiment and market returns\n",
    "5. Visualizes results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f17edf1d-0458-4d2a-8d96-b55ce845acb9",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Index(['ticker', 'type', 'id', 'parent_post_id', 'subreddit', 'title', 'text',\n",
       "       'url', 'upvotes', 'created_utc', 'author', 'word_count',\n",
       "       'author_created_utc'],\n",
       "      dtype='object')"
      ]
     },
     "execution_count": 23,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Import required libraries\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import yfinance as yf\n",
    "import statsmodels.api as sm\n",
    "\n",
    "# Load data files\n",
    "sp100 = pd.read_csv(\"sp100.csv\")\n",
    "print(\"SP100 columns:\", sp100.columns.tolist())\n",
    "\n",
    "# Load daily weighted sentiment\n",
    "daily_sentiment = pd.read_csv(\"daily_weighted_sentiment.csv\", index_col=[0])\n",
    "daily_sentiment.index.name = \"Date\"\n",
    "daily_sentiment.index = pd.to_datetime(daily_sentiment.index, errors='coerce')\n",
    "print(\"Daily sentiment loaded\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4f666164",
   "metadata": {},
   "source": [
    "## Load Market Data\n",
    "\n",
    "Download S&P 100 index data from Yahoo Finance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d4c6893c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Download S&P 100 index data\n",
    "ticker = [\"^OEX\"]\n",
    "stonks = yf.download(ticker, start=\"2015-01-01\", end=\"2025-05-16\").copy()\n",
    "\n",
    "# Reindex to include all days and forward fill missing values\n",
    "all_days = pd.date_range(start=\"2015-01-01\", end=\"2025-05-16\", freq=\"D\")\n",
    "close = stonks.Close.reindex(all_days).fillna(method=\"ffill\")\n",
    "\n",
    "# Calculate daily returns\n",
    "close[\"% Change\"] = close[\"^OEX\"].pct_change()\n",
    "close.index.name = \"Date\"\n",
    "\n",
    "print(f\"Market data loaded: {len(close)} days\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e6b23fc6",
   "metadata": {},
   "source": [
    "## Merge Data & Create Indicators\n",
    "\n",
    "Merge sentiment with market data and compute technical indicators."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b76f8e4e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge sentiment with market data\n",
    "merged3 = pd.merge(close, daily_sentiment, left_on='Date', right_index=True, how='inner')\n",
    "\n",
    "# Create various moving averages for weighted_sentiment\n",
    "for window in [3, 5, 10, 14, 21, 30]:\n",
    "    merged3[f'sentiment_ma{window}'] = merged3['weighted_sentiment'].rolling(window=window, min_periods=1).mean()\n",
    "\n",
    "# Exponentially Weighted Moving Averages (EWMA)\n",
    "for span in [3, 7, 14, 21, 30, 40, 50, 60, 90, 100, 250]:\n",
    "    merged3[f'sentiment_ewma{span}'] = merged3['weighted_sentiment'].ewm(span=span).mean()\n",
    "\n",
    "# Custom EWMA with specific decay rates\n",
    "merged3['sentiment_ewma_custom'] = merged3['weighted_sentiment'].ewm(alpha=0.4).mean()\n",
    "\n",
    "# Momentum indicators (rate of change)\n",
    "merged3['sentiment_momentum3'] = merged3['weighted_sentiment'] - merged3['sentiment_ma3'].shift(3)\n",
    "merged3['sentiment_momentum7'] = merged3['weighted_sentiment'] - merged3['sentiment_ma7'].shift(7)\n",
    "\n",
    "# Sentiment volatility (rolling standard deviation)\n",
    "merged3['sentiment_vol7'] = merged3['weighted_sentiment'].rolling(window=7).std()\n",
    "merged3['sentiment_vol14'] = merged3['weighted_sentiment'].rolling(window=14).std()\n",
    "\n",
    "# Z-score normalization\n",
    "merged3['sentiment_zscore7'] = (merged3['weighted_sentiment'] - merged3['sentiment_ma7']) / merged3['sentiment_vol7']\n",
    "merged3['sentiment_zscore14'] = (merged3['weighted_sentiment'] - merged3['sentiment_ma14']) / merged3['sentiment_vol14']\n",
    "\n",
    "print(\"New columns added:\", merged3.columns.tolist())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7566af97",
   "metadata": {},
   "source": [
    "## Correlation Analysis\n",
    "\n",
    "Analyze correlation between sentiment indicators and market returns."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "85606fe0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Quick correlation analysis with S&P 100 returns\n",
    "print(\"\\nCorrelation with % Change (S&P 100 returns):\")\n",
    "correlation_cols = ['weighted_sentiment', 'sentiment_ma7', 'sentiment_ma3', 'sentiment_ma5', \n",
    "                   'sentiment_ma10', 'sentiment_ma14', 'sentiment_ma21', 'sentiment_ma30',\n",
    "                   'sentiment_ewma3', 'sentiment_ewma7', 'sentiment_ewma14','sentiment_ewma21',\n",
    "                   'sentiment_ewma30','sentiment_ewma40','sentiment_ewma50', 'sentiment_ewma60',\n",
    "                   'sentiment_ewma90','sentiment_ewma100','sentiment_ewma250',\n",
    "                   'sentiment_momentum3', 'sentiment_momentum7', 'sentiment_zscore7']\n",
    "\n",
    "for col in correlation_cols:\n",
    "    if col in merged3.columns:\n",
    "        corr = merged3['^OEX'].corr(merged3[col])\n",
    "        print(f\"{col}: {corr:.6f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f79dda79",
   "metadata": {},
   "source": [
    "## Analyze ETH Sentiment\n",
    "\n",
    "Process ETH (Ethereum) Reddit data and visualize daily sentiment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8918927d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Process ETH sentiment data\n",
    "csv_file = 'ETH.csv'\n",
    "df = pd.read_csv(csv_file)\n",
    "\n",
    "# Filter valid rows\n",
    "df_valid = df[df['created_utc'].notna() & df['sentiment_compound'].notna()].copy()\n",
    "\n",
    "# Convert timestamps and extract date\n",
    "df_valid['created_utc'] = pd.to_datetime(df_valid['created_utc'])\n",
    "df_valid['Date'] = df_valid['created_utc'].dt.date\n",
    "df_valid['sentiment_compound'] = pd.to_numeric(df_valid['sentiment_compound'], errors='coerce').fillna(0)\n",
    "\n",
    "# Aggregate: mean sentiment per day\n",
    "sentiment_by_day = df_valid.groupby('Date')['sentiment_compound'].mean().reset_index()\n",
    "sentiment_by_day['Date'] = pd.to_datetime(sentiment_by_day['Date'])\n",
    "sentiment_by_day['sentiment_ma7'] = sentiment_by_day['sentiment_compound'].rolling(window=7, min_periods=1).mean()\n",
    "\n",
    "print(f\"ETH data: {len(sentiment_by_day)} days\")"
   ]
  },
  {
